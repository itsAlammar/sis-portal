# Copy to terraform.tfvars and fill in. Do NOT commit the real file.

hcloud_token    = "your-hetzner-cloud-api-token"
ssh_public_key  = "ssh-ed25519 AAAA... you@host"
container_image = "ghcr.io/<you>/sis:latest" # push the image here first

db_password    = "change-me-strong-password"
sis_secret_key = "change-me-long-random-string"

# Optional:
# location        = "nbg1"   # or fsn1, hel1
# app_count       = 2
# app_server_type = "cx22"
