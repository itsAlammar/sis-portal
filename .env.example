# Copy to .env (or export in your shell / secrets manager) before deploying.

# REQUIRED in production: session-signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SIS_SECRET_KEY=

# Set to 1 ONLY for local development -- enables the Werkzeug debugger,
# which allows remote code execution if exposed to a network.
SIS_DEBUG=
